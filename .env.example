# ═══════════════════════════════════════════════════════════
# La Cosmetikera — Variables de entorno (plantilla)
# Copia este archivo como .env.local y completa los valores
# ═══════════════════════════════════════════════════════════

# ── SUPABASE ────────────────────────────────────────────────
# Encuéntralos en: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── POS / IMPRESORA TÉRMICA ──────────────────────────────────
NEXT_PUBLIC_POS_PRINTER_NAME=
NEXT_PUBLIC_POS_PRINTER_WIDTH=32

# ── TIENDA ──────────────────────────────────────────────────
NEXT_PUBLIC_TIENDA_NOMBRE=La Cosmetikera
NEXT_PUBLIC_TIENDA_NIT=
NEXT_PUBLIC_TIENDA_DIRECCION=
NEXT_PUBLIC_TIENDA_TELEFONO=
NEXT_PUBLIC_TIENDA_MENSAJE_TICKET=¡Gracias por tu compra!