# ═══════════════════════════════════════════════════════════
# La Cosmetikera — Variables de entorno (plantilla)
# Copia este archivo como .env.local y completa los valores
# ═══════════════════════════════════════════════════════════

# ── SUPABASE ────────────────────────────────────────────────
# Encuéntralos en: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── WEB PUSH (VAPID) ───────────────────────────────────────
# Genera estas claves con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu_vapid_public_key_aqui
VAPID_PRIVATE_KEY=tu_vapid_private_key_aqui
VAPID_SUBJECT=mailto:admin@lacosmetikera.com

# ── POS / IMPRESORA TÉRMICA ──────────────────────────────────
# auto: intenta agente local y si falla abre impresión de navegador
# agent: exige agente local (sin fallback automático)
# qz: usa QZ Tray
# browser: siempre navegador
NEXT_PUBLIC_POS_PRINT_MODE=auto
NEXT_PUBLIC_POS_AGENT_URL=http://127.0.0.1:17891
# Opcional: mismo token configurado en POS_AGENT_TOKEN del PC de caja
NEXT_PUBLIC_POS_AGENT_TOKEN=
NEXT_PUBLIC_POS_PRINTER_NAME=
NEXT_PUBLIC_POS_PRINTER_WIDTH=32

# ── QZ TRAY (FIRMA DIGITAL) ──────────────────────────────────
# Certificado publico en formato PEM (puede ir en una sola linea con \n)
NEXT_PUBLIC_QZ_CERTIFICATE=
# Llave privada PEM para firmar en servidor (NO exponer en cliente)
QZ_PRIVATE_KEY=
# Alternativa a QZ_PRIVATE_KEY: la misma llave en base64
QZ_PRIVATE_KEY_BASE64=

# ── TIENDA ──────────────────────────────────────────────────
NEXT_PUBLIC_TIENDA_NOMBRE=La Cosmetikera
NEXT_PUBLIC_TIENDA_NIT=
NEXT_PUBLIC_TIENDA_DIRECCION=
NEXT_PUBLIC_TIENDA_TELEFONO=
NEXT_PUBLIC_TIENDA_MENSAJE_TICKET=¡Gracias por tu compra!

# ── WHATSAPP ─────────────────────────────────────────────────
# ID del número de teléfono en Meta Business (solo dígitos, sin +)
WHATSAPP_PHONE_NUMBER_ID=
# Token de acceso permanente de la app de Meta
WHATSAPP_ACCESS_TOKEN=
# API Key interna para que Make autentique sus llamadas
WHATSAPP_API_KEY=
# Número del bot que ven los clientes en el club (ej: 573101234567)
NEXT_PUBLIC_WHATSAPP_BOT_NUMBER=